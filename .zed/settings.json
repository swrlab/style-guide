{
	"languages": {
		"JSON": {
			"language_servers": ["prettier", "eslint", "..."],
			"formatter": {
				"language_server": {
					"name": "prettier"
				}
			},
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			},
			"format_on_save": "on"
		},
		"JSONC": {
			"language_servers": ["prettier", "eslint", "..."],
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			},
			"format_on_save": "on"
		},
		"JavaScript": {
			"formatter": {
				"language_server": {
					"name": "eslint"
				}
			},
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			},
			"prettier": {
				"allowed": false
			},
			"format_on_save": "on"
		},
		"TypeScript": {
			"language_servers": ["eslint", "!deno", "!biome", "..."],
			"formatter": {
				"language_server": {
					"name": "eslint"
				}
			},
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			},
			"prettier": {
				"allowed": true
			},
			"format_on_save": "on"
		}
	}
}
